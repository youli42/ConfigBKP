{
  "name": "Git",
  "description": "Git 全局配置",
  "version": 1,
  "enabled": true,
  "platform": "cross-platform",
  "paths": [
    "%USERPROFILE%\\.gitconfig",
    "%USERPROFILE%\\.gitignore_global"
  ],
  "parser_fields": {},
  "strategy": {
    "type": "incremental",
    "max_versions": 10,
    "ignore_patterns": []
  },
  "data_paths": [],
  "backup_scope": {
    "config": true,
    "data": false
  }
}