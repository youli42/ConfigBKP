{
  "name": "VS Code",
  "description": "Visual Studio Code 编辑器配置",
  "version": 1,
  "enabled": true,
  "platform": "windows",
  "paths": [
    "%APPDATA%\\Code\\User\\settings.json",
    "%APPDATA%\\Code\\User\\keybindings.json",
    "%APPDATA%\\Code\\User\\snippets\\",
    "%APPDATA%\\Code\\User\\extensions.json"
  ],
  "parser_fields": {},
  "strategy": {
    "type": "incremental",
    "max_versions": 10,
    "ignore_patterns": ["*.log", "*.tmp"]
  }
}
