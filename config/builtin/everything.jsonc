{
  "name": "Everything",
  "description": "Everything 文件搜索工具配置",
  "version": 1,
  "enabled": true,
  "platform": "windows",
  "paths": [
    {
      "path": "%APPDATA%\\Everything\\Everything.ini",
      "desc": "Everything 主配置"
    }
  ],
  "parser_fields": {},
  "strategy": {
    "type": "incremental",
    "max_versions": 10,
    "ignore_patterns": []
  },
  "data_paths": [],
  "backup_scope": {
    "config": true,
    "data": false
  }
}
